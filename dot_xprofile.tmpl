#!/usr/bin/env sh 

{{- if (eq .chezmoi.os "darwin") -}}
export HOME="/Users/{{ .chezmoi.username }}"
{{ else if eq .chezmoi.os "linux" }}
export HOME="{{ .chezmoi.homeDir }}"
{{- end }}

export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.config/local"
export XRDM_DIR="$HOME/.Xresource.d"
export XRDM_FONT_DIR="$HOME/fonts"
export XRDM_COLOR_DIR="$HOME/colors"
export XRDM_PRESET_DIR="$HOME/presets"
export XRDM_PROGRAM_DIR="$HOME/programs"

source "$HOME/.bashrc"

# Running some things here...

{{ if eq .chezmoi.os "linux" }}
eval $(gnome-keyring-daemon --start)
# export SSH_AUTH_SOCK

# picom &
xcompmgr -c &
dunst &

sxhkd &

# xset r rate 300 50 &
redshift &

POLKIT_AGENT="/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1"
if [ -f "$POLKIT_AGENT" ]; then
  $POLKIT_AGENT &
fi

nitrogen --restore
# xrdm preset default
{{- end }}
